// ==================== CONTACT ====================
app.post('/api/contact', async (req, res) => {
  const created = await ContactMessage.create(req.body);
  res.status(201).json({ success: true, id: created._id });
});

app.get('/api/contact', authRequired, async (req, res) => {
  const messages = await ContactMessage.find().sort({ createdAt: -1 });
  res.json(messages);
});

app.delete('/api/contact/:id', authRequired, async (req, res) => {
